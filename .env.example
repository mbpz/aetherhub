# PostgreSQL database connection
DATABASE_URL=postgresql://user:password@localhost:5432/aetherhub

# OpenAI API Key (用于 Codex 代码生成)
OPENAI_API_KEY=your_openai_api_key_here

# Codex 配置
CODEX_MODEL=codex-3.5
CODEX_MAX_TOKENS=4096

# Z3 验证器配置
Z3_TIMEOUT=30

# Wasm 执行配置
WASM_MEMORY_LIMIT=16
WASM_TIME_LIMIT=5000

# 安全规则配置
MAX_LOOP_DEPTH=1000
MAX_FILE_SIZE=104857600

# GitHub OAuth 配置
# 获取方式：https://github.com/settings/developers → New OAuth App
# 授权回调 URL：http://localhost:8000/api/v1/auth/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:8000/api/v1/auth/callback

# JWT 配置
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
